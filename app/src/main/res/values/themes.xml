<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- All activities use NoActionBar — each layout has its own Toolbar -->
    <style name="Theme.SugarSaathi" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/saffron</item>
        <item name="colorPrimaryDark">@color/saffron_dark</item>
        <item name="colorAccent">@color/saffron</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/saffron_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Alias kept for manifest references — same as above -->
    <style name="Theme.SugarSaathi.WithActionBar" parent="Theme.SugarSaathi"/>

    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="AppToolbar" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">@color/saffron</item>
        <item name="titleTextColor">@color/white</item>
        <item name="navigationIcon">@drawable/ic_arrow_back</item>
    </style>
</resources>