<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:indicatorColor="@color/saffron"
            app:trackCornerRadius="4dp"
            android:max="3"
            android:progress="1" />

        <!-- Step 1: Welcome + Name + Language -->
        <LinearLayout
            android:id="@+id/stepWelcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_welcome_title"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/saffron"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_welcome_subtitle"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="32dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/onboarding_name_hint"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="24dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_select_language"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnLangEn"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="English"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <Button
                    android:id="@+id/btnLangHi"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="हिंदी"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Step 2: Family Photo -->
        <LinearLayout
            android:id="@+id/stepPhoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_photo_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_photo_subtitle"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <ImageView
                android:id="@+id/imgFamilyPhoto"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnPickPhoto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_pick_photo"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvPhotoHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_photo_hint"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Step 3: Notification time -->
        <LinearLayout
            android:id="@+id/stepNotification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_notif_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_notif_subtitle"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <TimePicker
                android:id="@+id/timePicker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:timePickerMode="spinner"/>
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="32dp"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_next"
            android:backgroundTint="@color/saffron"/>

        <Button
            android:id="@+id/btnFinish"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/onboarding_btn_finish"
            android:backgroundTint="@color/saffron"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>