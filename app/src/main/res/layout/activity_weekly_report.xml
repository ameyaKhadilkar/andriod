<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <include layout="@layout/include_toolbar"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Days count -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/saffron">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">
                    <TextView
                        android:id="@+id/tvDaysCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/7 days"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/tvSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.3"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Day by day row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">
                <TextView android:id="@+id/day1" android:layout_width="40dp" android:layout_height="40dp"
                    android:gravity="center" android:textSize="10sp" android:textColor="@color/white"
                    android:background="@drawable/bg_day_neutral" android:layout_margin="2dp"/>
                <TextView android:id="@+id/day2" android:layout_width="40dp" android:layout_height="40dp"
                    android:gravity="center" android:textSize="10sp" android:textColor="@color/white"
                    android:background="@drawable/bg_day_neutral" android:layout_margin="2dp"/>
                <TextView android:id="@+id/day3" android:layout_width="40dp" android:layout_height="40dp"
                    android:gravity="center" android:textSize="10sp" android:textColor="@color/white"
                    android:background="@drawable/bg_day_neutral" android:layout_margin="2dp"/>
                <TextView android:id="@+id/day4" android:layout_width="40dp" android:layout_height="40dp"
                    android:gravity="center" android:textSize="10sp" android:textColor="@color/white"
                    android:background="@drawable/bg_day_neutral" android:layout_margin="2dp"/>
                <TextView android:id="@+id/day5" android:layout_width="40dp" android:layout_height="40dp"
                    android:gravity="center" android:textSize="10sp" android:textColor="@color/white"
                    android:background="@drawable/bg_day_neutral" android:layout_margin="2dp"/>
                <TextView android:id="@+id/day6" android:layout_width="40dp" android:layout_height="40dp"
                    android:gravity="center" android:textSize="10sp" android:textColor="@color/white"
                    android:background="@drawable/bg_day_neutral" android:layout_margin="2dp"/>
                <TextView android:id="@+id/day7" android:layout_width="40dp" android:layout_height="40dp"
                    android:gravity="center" android:textSize="10sp" android:textColor="@color/white"
                    android:background="@drawable/bg_day_neutral" android:layout_margin="2dp"/>
            </LinearLayout>

            <!-- Notes from difficult days -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/report_what_happened"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/tvNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btnShare"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/report_share_whatsapp"
                android:backgroundTint="@color/whatsapp_green"
                android:textColor="@color/white"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>